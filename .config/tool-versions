# Pinned dev-tool versions. Read by scripts/bootstrap.sh and CI.
# Format: NAME=version (go-install tag/pseudo-version, or PyPI version for uvx tools).
# The `# renovate:` annotations let Renovate keep each pin current (see renovate.json).
# Go tools use v-prefixed tags; ZIZMOR is a PyPI tool (bare version) consumed via
# `uvx zizmor==<version>` by scripts/audit-workflows.sh.

# renovate: datasource=go depName=github.com/golangci/golangci-lint/v2
GOLANGCI_LINT=v2.4.0
# renovate: datasource=go depName=golang.org/x/vuln
GOVULNCHECK=v1.1.4
# renovate: datasource=go depName=github.com/zricethezav/gitleaks/v8
GITLEAKS=v8.21.2
# renovate: datasource=go depName=github.com/rhysd/actionlint
ACTIONLINT=v1.7.12
# renovate: datasource=pypi depName=zizmor
ZIZMOR=1.26.1
